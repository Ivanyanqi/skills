# ============================================================
# ~/.config/mise/config.toml — mise 全局版本配置
#
# 管理 Node.js、Python、Java、Maven 等运行时版本
# 修改后运行 `mise install` 使配置生效
# ============================================================

[tools]
# Node.js LTS
node = "22"

# Python
python = "3.12"

# Java（按需取消注释）
# java = "temurin-21"

# Maven（需要 Java）
# maven = "3.9"

[settings]
# 自动安装缺失版本
auto_install = true
